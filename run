#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

echo -e "${YELLOW}🔍 Проверка запущенных сервисов...${NC}"

# Parse arguments
RUN_CHECKS=false
for arg in "$@"; do
  if [ "$arg" == "--check" ]; then
    RUN_CHECKS=true
  fi
done

# Run checks if requested
if [ "$RUN_CHECKS" = true ]; then
  echo -e "${YELLOW}🛠 Запуск проверок кода (Linting & TypeScript)...${NC}"
  (
    cd "$ROOT_DIR/frontend"
    if [ ! -d "node_modules" ]; then
      npm install
    fi
    echo -e "${BLUE}▶ Linting...${NC}"
    npm run lint
    echo -e "${BLUE}▶ Type checking...${NC}"
    npm run type-check
  )
  if [ $? -ne 0 ]; then
    echo -e "${RED}❌ Проверки не пройдены. Исправьте ошибки перед запуском.${NC}"
    exit 1
  fi
  echo -e "${GREEN}✅ Код прошел проверки.${NC}\n"
fi

# Kill processes on ports if they exist
PORTS=(8000 3000)
for port in "${PORTS[@]}"; do
  if lsof -ti:$port >/dev/null 2>&1; then
    echo -e "${YELLOW}   Остановка сервиса на порту $port...${NC}"
    lsof -ti:$port | xargs kill -9 2>/dev/null || true
    sleep 0.5
  fi
done

# Remove Next.js lock files
echo -e "${YELLOW}🧹 Очистка lock файлов...${NC}"
find "$ROOT_DIR/frontend" -name "lock" -path "*/.next/dev/lock" -delete 2>/dev/null || true

echo -e "${GREEN}✅ Очистка завершена${NC}\n"

# Ensure air is installed for Go hot reload
AIR_BIN_DIR="$(go env GOPATH)/bin"
if ! command -v air >/dev/null 2>&1; then
  echo -e "${YELLOW}📦 Установка air для hot reload...${NC}"
  go install github.com/air-verse/air@latest
  echo -e "${GREEN}✅ Air установлен${NC}\n"
fi

# Ensure Go bin is on PATH (for air)
export PATH="$AIR_BIN_DIR:$PATH"

echo -e "${GREEN}🚀 Запуск ZooPlatforma...${NC}"
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${RED}Backend API:${NC}        http://localhost:8000"
echo -e "${BLUE}Frontend:${NC}           http://localhost:3000"
echo -e "  ${BLUE}├─ Main:${NC}          http://localhost:3000/main"
echo -e "  ${BLUE}├─ Owner:${NC}         http://localhost:3000/owner"
echo -e "  ${BLUE}├─ Admin:${NC}         http://localhost:3000/admin"
echo -e "  ${BLUE}├─ PetHelper:${NC}     http://localhost:3000/pethelper"
echo -e "  ${BLUE}└─ PetID:${NC}         http://localhost:3000/petid"
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}\n"

# Run Go backend with air (8000)
(
  cd "$ROOT_DIR/backend"
  echo -e "${RED}[BACKEND:8000]${NC} Проверка зависимостей Go..."
  go mod tidy
  
  echo -e "${RED}[BACKEND:8000]${NC} Запуск Go API с hot reload..."
  export PATH="$AIR_BIN_DIR:$PATH"
  FORCE_COLOR=1 PORT=8000 air 2>&1 | while IFS= read -r line; do
    echo -e "${RED}[BACKEND:8000]${NC} $line"
  done
) &
BACKEND_PID=$!

# Wait a bit for backend to start
sleep 2

# Frontend (3000)
(
  cd "$ROOT_DIR/frontend"
  echo -e "${BLUE}[FRONTEND:3000]${NC} Запуск Next.js..."
  
  # Check if node_modules exists
  if [ ! -d "node_modules" ]; then
    echo -e "${BLUE}[FRONTEND:3000]${NC} Установка зависимостей..."
    npm install
  fi
  
  FORCE_COLOR=1 NODE_OPTIONS=--no-deprecation npm run dev 2>&1 | while IFS= read -r line; do
    echo -e "${BLUE}[FRONTEND:3000]${NC} $line"
  done
) &
FRONTEND_PID=$!

# Trap Ctrl+C and cleanup
cleanup() {
  echo -e "\n${YELLOW}🛑 Остановка всех сервисов...${NC}"
  kill $BACKEND_PID $FRONTEND_PID 2>/dev/null || true
  
  # Force kill if still running
  sleep 1
  for port in "${PORTS[@]}"; do
    if lsof -ti:$port >/dev/null 2>&1; then
      lsof -ti:$port | xargs kill -9 2>/dev/null || true
    fi
  done
  
  echo -e "${GREEN}✅ Все сервисы остановлены${NC}"
  exit 0
}

trap cleanup SIGINT SIGTERM

# Wait for both processes
wait
